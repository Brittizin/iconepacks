<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.PocketDeck" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:statusBarColor">@color/breakcore_bg</item>
        <item name="android:navigationBarColor">@color/breakcore_bg</item>
        <item name="android:windowBackground">@color/breakcore_bg</item>
        <item name="android:textColorPrimary">@color/breakcore_text</item>
        <item name="colorPrimary">@color/breakcore_red</item>
        <item name="colorPrimaryContainer">@color/breakcore_panel_alt</item>
        <item name="colorOnPrimary">@color/breakcore_text</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Theme.PocketDeck.Splash" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_bg</item>
        <item name="android:statusBarColor">@color/breakcore_bg</item>
        <item name="android:navigationBarColor">@color/breakcore_bg</item>
    </style>
</resources>
